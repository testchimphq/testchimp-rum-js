{
  "name": "testchimp-rum-js",
  "version": "0.0.3",
  "description": "Lightweight browser library for emitting structured user interaction events to TestChimp",
  "main": "dist/testchimp-rum.min.js",
  "module": "dist/testchimp-rum.mjs",
  "unpkg": "dist/testchimp-rum.min.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:umd && npm run build:types",
    "build:esm": "esbuild src/index.ts --bundle --format=esm --outfile=dist/testchimp-rum.mjs --minify",
    "build:umd": "esbuild src/index.ts --bundle --format=iife --global-name=testchimp --outfile=dist/testchimp-rum.min.js --minify",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "testchimp",
    "rum",
    "real-user-monitoring",
    "analytics",
    "events"
  ],
  "author": "TestChimp",
  "license": "MIT"
}
